FROM node:22.23.1-bookworm-slim
WORKDIR /app
ENV NODE_ENV=production
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force
COPY server ./server
COPY scripts/black-cloud-execution-worker.js ./scripts/black-cloud-execution-worker.js
USER node
EXPOSE 8080
CMD ["node", "scripts/black-cloud-execution-worker.js"]
