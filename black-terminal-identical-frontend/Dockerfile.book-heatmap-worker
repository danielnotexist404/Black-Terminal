FROM node:22.23.1-bookworm-slim
WORKDIR /app
ENV NODE_ENV=production
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force
COPY server ./server
COPY scripts/book-heatmap-history-worker.js ./scripts/book-heatmap-history-worker.js
USER node
CMD ["node", "scripts/book-heatmap-history-worker.js"]
