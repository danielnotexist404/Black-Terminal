# Black Terminal - Bybit mainnet validation environment template
# Copy variable names into Vercel, the private-stream worker host, or the local operator shell as documented.
# Never commit real values. Never expose secret values with a VITE_ prefix.

# Server/Vercel non-secret configuration
SUPABASE_URL=
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_PRIVATE_WS_URL=wss://stream.bybit.com/v5/private
BYBIT_NETWORK=mainnet
BYBIT_MAINNET_VALIDATION_ENABLED=false
BYBIT_MAINNET_ALLOWED_CONNECTIONS=
BYBIT_MAINNET_ALLOWED_SYMBOLS=*
BYBIT_MAINNET_MAX_NOTIONAL_USD=
BYBIT_MAINNET_VALIDATION_ADMIN_EMAILS=

# Server/Vercel secrets
SUPABASE_SERVICE_ROLE_KEY=
EXCHANGE_CREDENTIAL_MASTER_KEY=

# Persistent private-stream worker configuration
BYBIT_PRIVATE_STREAM_RUNTIME_ENABLED=false
BYBIT_STREAM_ACCOUNT_ID=
BYBIT_STREAM_SYMBOL=BTCUSDT
BYBIT_STREAM_SUPERVISOR_RESTART_BASE_MS=1500
BYBIT_STREAM_SUPERVISOR_RESTART_MAX_MS=60000
BYBIT_STREAM_SUPERVISOR_MAX_RESTARTS=12
BYBIT_STREAM_SUPERVISOR_WINDOW_MS=300000

# Local operator certification runner configuration
BYBIT_CERTIFY_ACCOUNT_ID=
BYBIT_CERTIFY_SYMBOL=BTCUSDT
BYBIT_CERTIFY_API_BASE_URL=
BYBIT_CERTIFY_USER_TOKEN=
BYBIT_CERTIFY_CONFIRMATION=
BYBIT_CERTIFY_MAX_CLOCK_SKEW_MS=3000
BYBIT_CERTIFY_PRIVATE_STREAM_FRESH_MS=60000
BYBIT_CERTIFY_OPERATOR_PAUSE=true
BYBIT_CERTIFY_INCLUDE_REVERSE=false
BYBIT_CERTIFY_ALLOW_EXISTING_EXPOSURE=false
BYBIT_CERTIFY_LIMIT_OFFSET_BPS=300
BYBIT_CERTIFY_PROTECTION_OFFSET_BPS=120
