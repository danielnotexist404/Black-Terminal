{
  "name": "black-terminal-pixi",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "depth:worker": "node scripts/market-depth-worker.js",
    "depth:worker:supervise": "node scripts/market-depth-supervisor.js",
    "depth:verify": "node scripts/market-depth-verify.js",
    "perf:baseline": "node scripts/performance-baseline.js",
    "perf:stress": "node scripts/performance-stress.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check": "npm run typecheck && npm run check:rust"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.33.1",
    "@supabase/supabase-js": "^2.108.2",
    "@tauri-apps/api": "^2.5.0",
    "lucide-react": "^0.468.0",
    "pixi.js": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.54.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
